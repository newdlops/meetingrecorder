{
  "name": "meeting-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "회의 녹음, 실시간 전사, 화자 구분을 위한 Electron 앱",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock-system-audio": "MEETING_RECORDER_SYSTEM_AUDIO_MODE=mock electron-vite dev",
    "reset:system-audio-permission": "node scripts/reset-system-audio-permission.mjs",
    "build:system-audio": "node scripts/build-system-audio-recorder.mjs",
    "build": "npm run build:system-audio && tsc --noEmit && electron-vite build",
    "build:prod": "npm run dist",
    "dist": "npm run setup:standalone && npm run build && npm run verify:engine-bundle && electron-builder",
    "dist:dir": "npm run setup:standalone && npm run build && npm run verify:engine-bundle && electron-builder --dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "setup:stt": "python3 -m venv --clear --copies .venv-stt && .venv-stt/bin/python -m pip install --upgrade pip && .venv-stt/bin/python -m pip install -r engines/offline-whisperx/requirements.txt",
    "setup:engine-assets": ".venv-stt/bin/python scripts/setup-engine-assets.py",
    "setup:whisper-cpp": "node scripts/setup-whisper-cpp.mjs",
    "setup:standalone": "npm run setup:stt && npm run setup:engine-assets && npm run setup:whisper-cpp",
    "verify:engine-bundle": "node scripts/verify-engine-bundle.mjs"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.meetingrecorder.app",
    "productName": "Meeting Recorder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "engines/offline-whisperx",
        "to": "engines/offline-whisperx"
      },
      {
        "from": "engines/models",
        "to": "engines/models"
      },
      {
        "from": "engines/whisper.cpp",
        "to": "engines/whisper.cpp"
      },
      {
        "from": ".venv-stt",
        "to": ".venv-stt"
      },
      {
        "from": "native/macos-system-audio-recorder/build/SystemAudioRecorder.app",
        "to": "native/SystemAudioRecorder.app"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSAudioCaptureUsageDescription": "영상 자료의 시스템 오디오를 녹음해 회의록 전사 품질을 테스트합니다.",
        "NSMicrophoneUsageDescription": "회의 음성을 녹음하고 오프라인으로 전사하기 위해 마이크를 사용합니다."
      }
    }
  }
}
